<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AutoPayPlus — Onboarding Journey Comparison</title>
<style>
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:#f5f5f0;color:#1a1a1a;padding:24px;min-height:100vh;}
.container{max-width:1100px;margin:0 auto;}
.page-header{margin-bottom:20px;}
.page-header h1{font-size:20px;font-weight:600;color:#0C3A5E;margin-bottom:4px;}
.page-header p{font-size:13px;color:#666;line-height:1.5;}
.banner{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:16px;}
.issue-bar{border-radius:10px;padding:12px 14px;border:1px solid;font-size:12px;line-height:1.6;}
.issue-warn{background:#fffbeb;border-color:#fcd34d;}
.issue-neutral{background:#fff;border-color:#e5e5e5;}
.issue-title-warn{font-weight:600;color:#92400e;margin-bottom:4px;font-size:13px;}
.issue-title-neutral{font-weight:600;color:#111;margin-bottom:4px;font-size:13px;}
.issue-body{color:#555;}
.pill{display:inline-block;font-size:10px;font-weight:600;padding:2px 8px;border-radius:10px;margin-top:6px;}
.pill-orange{background:#F5A623;color:#0C3A5E;}
.pill-red{background:#fee2e2;color:#991b1b;border:1px solid #fca5a5;}
.pill-green{background:#dcfce7;color:#166534;border:1px solid #86efac;}
.pill-blue{background:#dbeafe;color:#1e40af;border:1px solid #93c5fd;}
.tabs{display:flex;gap:2px;border-bottom:1px solid #ddd;flex-wrap:wrap;margin-bottom:0;}
.tab{cursor:pointer;padding:8px 12px 7px;font-size:11px;border:1px solid #ddd;border-bottom:none;border-radius:6px 6px 0 0;color:#666;background:#f0f0ec;line-height:1.3;text-align:left;transition:all .12s;}
.tab:hover{color:#0C3A5E;}
.tab.active{background:#fff;color:#0C3A5E;border-color:#ddd;border-bottom-color:#fff;z-index:1;}
.tab-id{font-weight:600;font-size:12px;display:block;}
.tab-desc{font-size:10px;color:#888;display:block;margin-top:1px;}
.tab.active .tab-desc{color:#888;}
.summary{display:grid;grid-template-columns:1.6fr 1fr 1fr;gap:8px;margin:12px 0 14px;background:#fff;padding:12px;border:1px solid #ddd;border-top:none;border-radius:0 0 0 0;}
.sum-card{border-radius:8px;padding:10px 12px;border:1px solid;}
.sum-neutral{background:#f8f8f8;border-color:#e5e5e5;}
.sum-red{background:#fef2f2;border-color:#fca5a5;}
.sum-green{background:#f0fdf4;border-color:#86efac;}
.sum-label{font-size:10px;margin-bottom:3px;}
.sum-label-neutral{color:#666;}
.sum-label-red{color:#dc2626;}
.sum-label-green{color:#16a34a;}
.sum-id{font-size:11px;color:#888;}
.sum-title{font-size:13px;font-weight:600;color:#111;margin:1px 0 2px;}
.sum-sub{font-size:11px;color:#555;line-height:1.4;}
.sum-val-red{font-size:12px;font-weight:600;color:#dc2626;}
.sum-val-green{font-size:12px;font-weight:600;color:#16a34a;}
.cols{display:grid;grid-template-columns:1fr 1fr;gap:14px;background:#fff;padding:12px;border:1px solid #ddd;border-top:none;border-radius:0 0 10px 10px;}
.col-header{display:flex;align-items:center;gap:8px;margin-bottom:10px;padding:8px 12px;border-radius:8px;border:1px solid;}
.col-header-red{background:#fef2f2;border-color:#fca5a5;}
.col-header-green{background:#f0fdf4;border-color:#86efac;}
.col-title-red{font-size:13px;font-weight:600;color:#dc2626;}
.col-title-green{font-size:13px;font-weight:600;color:#16a34a;}
.col-sub{font-size:11px;color:#666;margin-left:auto;}
.step-row{display:flex;gap:8px;align-items:flex-start;margin-bottom:0;}
.connector{width:18px;height:10px;display:flex;justify-content:center;flex-shrink:0;}
.connector::after{content:'';width:1px;height:100%;background:#ddd;display:block;}
.dot{width:18px;height:18px;border-radius:50%;border:1.5px solid;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:700;margin-top:2px;}
.dot-ok{border-color:#16a34a;color:#16a34a;}
.dot-br{border-color:#dc2626;color:#dc2626;}
.dot-wn{border-color:#d97706;color:#d97706;}
.dot-nu{border-color:#aaa;color:#aaa;}
.card{flex:1;border-radius:8px;padding:8px 10px;border:1px solid;margin-bottom:0;}
.card-ok{background:#f0fdf4;border-color:#86efac;}
.card-br{background:#fef2f2;border-color:#fca5a5;}
.card-wn{background:#fffbeb;border-color:#fcd34d;}
.card-nu{background:#f8f8f8;border-color:#e5e5e5;}
.card-dead{background-image:repeating-linear-gradient(-45deg,transparent,transparent 5px,rgba(200,50,50,.06) 5px,rgba(200,50,50,.06) 10px)!important;border-style:dashed!important;}
.step-name{font-size:10px;color:#888;margin-bottom:2px;}
.step-time-ok{font-size:13px;font-weight:600;color:#16a34a;}
.step-time-br{font-size:13px;font-weight:600;color:#dc2626;}
.step-time-wn{font-size:13px;font-weight:600;color:#d97706;}
.step-time-nu{font-size:13px;color:#555;}
.step-body{font-size:11px;color:#555;line-height:1.5;margin-top:3px;}
.badge{display:inline-block;font-size:10px;font-weight:600;padding:2px 7px;border-radius:4px;margin-top:5px;background:#F5A623;color:#0C3A5E;}
.badge-blue{background:#dbeafe;color:#1e40af;}
.note{font-size:10px;color:#777;border-left:2px solid #ddd;padding-left:6px;margin-top:5px;line-height:1.4;}
.pair{display:flex;gap:8px;align-items:flex-start;margin-bottom:0;}
.pair-spacer{display:flex;gap:8px;}
.pair-spacer-conn{width:18px;height:10px;display:flex;justify-content:center;flex-shrink:0;}
.pair-spacer-conn::after{content:'';width:1px;height:100%;background:#ddd;display:block;}
.footer{text-align:center;font-size:11px;color:#aaa;margin-top:16px;padding-top:12px;border-top:1px solid #eee;}
</style>
</head>
<body>
<div class="container">

<div class="page-header">
  <h1>AutoPayPlus — Onboarding Journey Comparison</h1>
  <p>Current state vs. MVP approach across all five member journey types &nbsp;·&nbsp; April 30, 2026 Decision Session &nbsp;·&nbsp; Confidential</p>
</div>

<div class="banner">
  <div class="issue-bar issue-warn">
    <div class="issue-title-warn">Open issue: affects every journey regardless of batch timing</div>
    <div class="issue-body">Even if we solved the dead zone entirely and onboarded members the moment they enrolled, the first messages they receive lead with authentication — not brand, not plan basics, not their first debit date or amount. The member is asked to verify their identity before they understand what they signed up for. This problem is independent of the batch process.</div>
    <span class="pill pill-orange">Level 1 EV2 SMS solves this at t=0 for every journey</span>
  </div>
  <div class="issue-bar issue-neutral">
    <div class="issue-title-neutral">Payor vs. primary: policy is set &nbsp;<span class="pill pill-green">Resolved</span></div>
    <div class="issue-body" style="margin-bottom:6px;">Per documentation and agreements, the <strong>primary on the plan receives onboarding</strong> — not the payor. This is the correct and documented rule.</div>
    <div style="font-weight:600;color:#b45309;margin-bottom:3px;font-size:12px;">Known friction: ~10% of cases <span class="pill" style="background:#fef3c7;color:#92400e;border:1px solid #fcd34d;">Design consideration</span></div>
    <div class="issue-body">When primary and payor differ (LLC, spouse, parent as payor) the primary may not have the payor's verification info needed to complete KBA. Example: daughter is primary, parent is payor — daughter cannot verify parent's financial details during onboarding.</div>
    <span class="pill pill-blue">MVP or Prospect Portal (7–9 screens) is the candidate solution</span>
  </div>
</div>

<div class="tabs" id="tabs"></div>
<div class="summary" id="summary"></div>
<div class="cols" id="cols"></div>

<div class="footer">AutoPayPlus Onboarding Task Force &nbsp;·&nbsp; April 30, 2026 &nbsp;·&nbsp; Confidential &nbsp;·&nbsp; Brad Hoppmann, Director of Retention and Renewals</div>
</div>

<script>
const ST={ok:{card:'card-ok',dot:'dot-ok',time:'step-time-ok',icon:'✓'},broken:{card:'card-br',dot:'dot-br',time:'step-time-br',icon:'✕'},warn:{card:'card-wn',dot:'dot-wn',time:'step-time-wn',icon:'!'},neutral:{card:'card-nu',dot:'dot-nu',time:'step-time-nu',icon:'·'}};

const D={
 '1a':{label:'Journey 1A',desc:'Weekday new member (Tue–Thu)',sub:'New member enrolled Tue–Thu · Jimmy runs the batch next morning · ~60% auto-onboard · most of the ~40% who need manual are processed same day',cur_tag:'Silent from enrollment until after batch — auth-first messaging',mvp_tag:'Context at enrollment, not hours later',steps:[
  {name:'Enrollment — EV2 record created',cur:{t:'t = 0',n:'Record created. EV2 Prospects populated. Member receives nothing. No brand context, no debit info, no indication of what happens next.',st:'neutral'},mvp:{t:'t = 0',n:'EV2 SMS fires immediately — brand intro, vehicle or property info, estimated first debit date and amount. Member has context before any authentication is requested.',st:'ok',b:'Level 1'}},
  {name:'Silent window before batch runs',dead:true,cur:{t:'~12–18 hrs',n:'Member cannot log in yet. Nothing has been communicated. They have agreed to a service that will debit their bank account and have no information about when or how much.',st:'broken'},mvp:{t:'Eliminated from member experience',n:'Dead zone exists in the system but not for the member. Plan summary was delivered at enrollment.',st:'ok'}},
  {name:"Jimmy's morning batch (next day ~8 AM)",cur:{t:'~12–18 hrs after enrollment',n:"Jimmy presses the button. ~60% auto-onboard automatically. The remaining ~40% require manual processing and are queued for same-day handling by staff.",st:'neutral'},mvp:{t:'~12–18 hrs — unchanged',n:'Batch runs as before. Members who auto-onboard are already informed. The 40% in manual queue also have plan context from the Level 1 SMS.',st:'neutral'}},
  {name:'Manual processing for the ~40%',cur:{t:'Same day — most cases',n:'Staff manually processes the queue. The majority are resolved the same day. Carryover to the next day in under 5% of cases on Tue–Thu, rising to 10–20% on Mondays due to weekend volume, and up to ~30% on post-holiday Mondays.',st:'warn',note:'Monday and post-holiday Mondays carry higher volume from weekend enrollments.'},mvp:{t:'Same day — most cases',n:'Processing timeline unchanged. Members in the manual queue have brand and debit context already. Less anxiety, lower cancellation risk.',st:'ok'}},
  {name:'Welcome email fires',cur:{t:'After onboarding completes',n:'First message leads with portal setup and authentication. No debit date or amount visible. Calendly buried. Member has not yet been told what the service does.',st:'warn'},mvp:{t:'After onboarding completes',n:'Member already knows the brand and their debit estimate. Calendly above the fold. Step 24 queued to fire 3 days before first debit.',st:'ok'}},
  {name:'Pre-debit reminder (Step 24)',cur:{t:'Never fires',n:'Step 24 is broken. No automated reminder before first debit regardless of onboarding path.',st:'broken'},mvp:{t:'3 days before first debit',n:'Step 24 fixed. Email + SMS fires automatically.',st:'ok',b:'Quick fix'}},
  {name:'First Value achieved',cur:{t:'Not achievable',n:'Debit date not visible. Step 24 broken. 30% of returning member sessions require full re-authentication. TFV cannot be confirmed.',st:'broken'},mvp:{t:'Within 72 hrs of onboarding',n:'Logged in + debit confirmed + payment schedule visible. TFV definition met.',st:'ok'}}
 ]},
 '1b':{label:'Journey 1B',desc:'Thursday order, Friday AM batch',sub:'Enrolled Thursday · Jimmy processes Thursday orders Friday at 8 AM · ~60% auto-onboard · ~40% need manual on a Friday, meaning carryover lands on Monday',cur_tag:'40% face a Friday manual queue — carryover means the full weekend',mvp_tag:'All members informed at enrollment regardless of Friday outcome',steps:[
  {name:'Enrollment Thursday (any time)',cur:{t:'Thursday t = 0',n:'Record created. Member receives nothing overnight.',st:'neutral'},mvp:{t:'Thursday t = 0',n:'EV2 SMS fires Thursday at enrollment. Member has plan context before the Friday batch even runs.',st:'ok',b:'Level 1'}},
  {name:'Overnight silent window',dead:true,cur:{t:'Thursday PM to Friday 8 AM',n:'12–18 hrs of silence. Member has no context about what they enrolled in.',st:'broken'},mvp:{t:'Eliminated',n:'Plan summary already delivered Thursday.',st:'ok'}},
  {name:"Jimmy's Friday 8 AM batch",cur:{t:'Friday ~8 AM',n:"Jimmy presses the button. Processes Thursday's prospects. ~60% auto-onboard. The remaining ~40% go to the manual queue for Friday staff to handle.",st:'neutral'},mvp:{t:'Friday ~8 AM — unchanged',n:'Batch runs as before. Auto-onboarded members are already informed. Manual queue members also have plan context from Thursday.',st:'neutral'}},
  {name:'Manual processing — Friday queue',cur:{t:'Friday, same day — most cases',n:'Staff works through the manual queue. Most resolved that day. Members who cannot be resolved by end of Friday carry over to Monday. There is no weekend processing.',st:'warn',note:'Friday carryover is more impactful than any other day — next processing window is Monday.'},mvp:{t:'Friday, same day — most cases',n:'Processing timeline unchanged. Members who carry to Monday already have plan context from Thursday enrollment.',st:'ok'}},
  {name:'Members carrying to Monday',cur:{t:'Full weekend — no communication',n:'Members unresolved on Friday wait Saturday and Sunday with no updates. First debit may arrive before onboarding completes.',st:'broken'},mvp:{t:'Weekend — informed wait',n:'Plan summary was delivered Thursday. Member has debit estimate. Level 1 SMS removes the surprise.',st:'ok'}},
  {name:'Pre-debit reminder (Step 24)',cur:{t:'Never fires',n:'Step 24 broken regardless of path.',st:'broken'},mvp:{t:'3 days before first debit',n:'Step 24 fixed. Critical for Thursday enrollees whose first debit may arrive the following week.',st:'ok',b:'Quick fix'}},
  {name:'First Value achieved',cur:{t:'Not achievable',n:'Debit date not visible. No TFV. Friday carryover members have the worst experience — longest silence, no defined endpoint.',st:'broken'},mvp:{t:'Within 72 hrs of onboarding',n:'TFV achievable for all members once the portal is reachable.',st:'ok'}}
 ]},
 '1c':{label:'Journey 1C',desc:'Friday after-8 AM — waits until Monday',sub:'Enrolled Friday after Jimmy already ran the batch · definite Monday wait · ~60% auto-onboard Monday · Monday is the highest-volume batch day',cur_tag:'Minimum 2.5-day silent dead zone before batch even runs',mvp_tag:'Informed Friday afternoon — weekend is not a dead zone',steps:[
  {name:'Enrollment Friday after 8 AM',cur:{t:'Missed the Friday batch',n:'Record created after Jimmy already pressed the button. Will not be processed until Monday morning at the earliest. Receives nothing.',st:'broken'},mvp:{t:'Friday t = 0',n:'EV2 SMS fires Friday at enrollment — afternoon or evening. Member has brand context, vehicle info, and debit estimate before the weekend.',st:'ok',b:'Level 1'}},
  {name:'Weekend dead zone',dead:true,cur:{t:'Friday PM through Monday AM',n:'Entire weekend with no communication. Member agreed to an automated payment service that will debit their bank account. No debit date, no amount, no company context. Highest-risk silence window in the enrolled population.',st:'broken'},mvp:{t:'Eliminated from member experience',n:'Member received plan summary Friday. Weekend is not a dead zone in their experience, only in the processing queue.',st:'ok'}},
  {name:"Monday morning batch",cur:{t:'Monday ~8 AM',n:"Jimmy presses Monday's button. Processes all Friday-after-8AM and weekend enrollments. Monday is the highest-volume batch day. ~60% auto-onboard. ~40% go to the manual queue.",st:'warn'},mvp:{t:'Monday ~8 AM — unchanged',n:'Batch runs as before. Auto-onboarded members are already informed from Friday. Manual queue members also have Friday context.',st:'neutral'}},
  {name:'Manual processing — Monday queue',cur:{t:'Monday, same day — most cases',n:'Monday has the largest manual queue of any day. 10–20% of manual cases carry to Tuesday on normal Mondays. On post-holiday Mondays, carryover can reach ~30%, with those members waiting until Wednesday.',st:'broken',note:'Post-holiday Mondays can push Wednesday before some members are onboarded — enrolled 4+ days earlier.'},mvp:{t:'Monday, same day — most cases',n:'Processing timeline unchanged. Monday manual queue members have had context since Friday. Informed wait, not silence.',st:'ok'}},
  {name:'Post-holiday carryover to Wednesday',cur:{t:'Up to ~30% on holiday Mondays',n:'Members who enrolled before a holiday weekend may not be fully onboarded until Wednesday — 5+ days from enrollment to first contact in worst cases.',st:'broken'},mvp:{t:'Still informed since enrollment',n:'These members received the Level 1 SMS at enrollment. The processing delay is still a problem, but it is not 5 days of silence.',st:'ok'}},
  {name:'Pre-debit reminder (Step 24)',cur:{t:'Never fires',n:'Step 24 broken. For Friday enrollees, first debit may arrive before any communication has been sent.',st:'broken'},mvp:{t:'3 days before first debit',n:'Step 24 fixed. For Friday enrollees, may be the only warning before a first debit arrives the following week.',st:'ok',b:'Quick fix'}},
  {name:'First Value achieved',cur:{t:'Not achievable',n:'Debit date not visible. No TFV. Worst-case path in the entire member population.',st:'broken'},mvp:{t:'Within 72 hrs of onboarding',n:'TFV achievable once portal is reachable. Member arrives already knowing their debit information.',st:'ok'}}
 ]},
 '2':{label:'Journey 2',desc:'New member, never auto-onboardable',sub:'New member who cannot auto-onboard regardless of day or timing · requires manual processing from the start · reason varies (missing data, lender type, etc.)',cur_tag:'1–4 days silent — no transparency on timeline or status',mvp_tag:'Context from day one — wait is expected, not mysterious',steps:[
  {name:'Enrollment — manual flag set',cur:{t:'t = 0',n:'Record created. Cannot auto-onboard. Enters manual queue immediately. Member receives nothing. No indication of what happens next.',st:'neutral'},mvp:{t:'t = 0',n:'EV2 SMS fires. Brand intro, vehicle, lender, estimated debit date and amount. Sets expectation that processing is underway.',st:'ok',b:'Level 1'}},
  {name:'Manual processing queue',dead:true,cur:{t:'Typically same day; next day in rare cases',n:'Most resolved the same business day. On Mondays, the larger queue increases next-day completion risk. Under 5% carry to next day Tue–Fri, 10–20% on Mondays. No communication during wait.',st:'broken'},mvp:{t:'Informed wait',n:'Plan summary already delivered. Member knows the service and their debit estimate. Inbound calls from confused members are reduced.',st:'ok'}},
  {name:'Onboarding completes (manually)',cur:{t:'Same business day — most cases',n:'No consistent timeline communicated to the member.',st:'warn'},mvp:{t:'Same business day — most cases',n:'Same processing time. Fundamentally different member experience during the wait.',st:'neutral'}},
  {name:'Welcome email fires',cur:{t:'After manual completes',n:'First message leads with authentication. No debit info. Calendly buried. Member may not connect this email to their enrollment.',st:'warn'},mvp:{t:'After manual completes',n:'Member already knows the brand. Calendly above fold. Step 24 queued.',st:'ok'}},
  {name:'Pre-debit reminder (Step 24)',cur:{t:'Never fires',n:'Step 24 broken.',st:'broken'},mvp:{t:'3 days before first debit',n:'Step 24 fixed.',st:'ok',b:'Quick fix'}},
  {name:'First Value achieved',cur:{t:'Not achievable',n:'Debit date not visible. TFV not met.',st:'broken'},mvp:{t:'Within 72 hrs of onboarding',n:'TFV achievable. Member arrives informed.',st:'ok'}}
 ]},
 '3':{label:'Journey 3',desc:'Existing member adding a new loan',sub:'Prior AutoPayPlus member or VIP adding a new loan · ALL are manually processed — no exceptions · treated identically to a first-timer today · payor/primary friction applies if they differ',cur_tag:'Years of relationship — zero recognition anywhere in the process',mvp_tag:'Returning member recognized from t=0 via smart lookup',steps:[
  {name:'New loan enrollment',cur:{t:'t = 0',n:'Prior membership exists in Creatio. VIP flag may be set. None of this has any effect. Routed into manual queue identically to a brand new member.',st:'broken'},mvp:{t:'t = 0',n:'EV2 SMS fires. Smart lookup at the plan summary page identifies prior membership. Welcome back experience from first contact.',st:'ok',b:'Level 1 + 2'}},
  {name:'Dead zone — stranger treatment',dead:true,cur:{t:'1–4 business days',n:'Member with years of AutoPayPlus history waits in the same queue as a first-timer. VIP flag has no visible effect. Prior relationship actively eroded.',st:'broken'},mvp:{t:'Informed wait',n:'Returning member flow acknowledges prior history. VIP concierge contact option surfaced. Relationship preserved.',st:'ok'}},
  {name:'Manual onboarding (mandatory for all)',cur:{t:'Same day — most cases',n:'No path to auto-onboard for existing members. No escalation for VIPs. Same Monday volume rules apply.',st:'broken'},mvp:{t:'Same day — most cases',n:'Same processing time. Differentiated experience throughout. VIP flag active from enrollment.',st:'neutral'}},
  {name:'First contact / welcome communication',cur:{t:'After manual completes',n:'Same email template as first-timers. No mention of prior membership. No VIP acknowledgment.',st:'broken'},mvp:{t:'After manual completes',n:'Returning member email references prior history. VIP concierge option included.',st:'ok',b:'Level 2'}},
  {name:'VIP recognition',cur:{t:'Never',n:'VIP flag exists in Creatio. Has zero effect on what the member sees or experiences at any stage.',st:'broken'},mvp:{t:'From t = 0',n:'VIP flag activates elevated experience at EV2 SMS. Concierge contact option available throughout.',st:'ok'}},
  {name:'Payor/primary friction (if they differ)',cur:{t:'Unaddressed — member gets stuck',n:"If the primary cannot verify the payor's information during KBA, the process fails. Estimated ~10% of enrollments. No alternate path exists today.",st:'broken'},mvp:{t:'Candidate solution — Prospect Portal',n:'MVP or full Prospect Portal (7–9 new screens) provides an alternate verification path. Primary and payor can be handled separately without blocking onboarding.',st:'warn',b:'Design consideration'}},
  {name:'First Value achieved',cur:{t:'Not achievable',n:'Debit date not visible. Relationship eroded. Payor/primary mismatch cases may never complete onboarding.',st:'broken'},mvp:{t:'Within 72 hrs of onboarding',n:'TFV met for standard cases. Payor/primary edge case addressed via Prospect Portal design.',st:'ok'}}
 ]}
};

let cur='1a';

function renderStep(step, side) {
  const d = side==='cur' ? step.cur : step.mvp;
  const s = ST[d.st];
  const dead = step.dead && side==='cur';
  return `<div class="card ${s.card}${dead?' card-dead':''}">
    <div class="step-name">${step.name}</div>
    <div class="${s.time}">${d.t}</div>
    <div class="step-body">${d.n}</div>
    ${d.b?`<span class="badge">${d.b}</span>`:''}
    ${d.note?`<div class="note">${d.note}</div>`:''}
  </div>`;
}

function renderCol(steps, side) {
  return steps.map((step,i) => `
    ${i>0?`<div class="pair-spacer"><div class="pair-spacer-conn"></div><div style="flex:1"></div></div>`:''}
    <div class="step-row">
      <div class="dot ${ST[side==='cur'?step.cur.st:step.mvp.st].dot}">${ST[side==='cur'?step.cur.st:step.mvp.st].icon}</div>
      ${renderStep(step, side)}
    </div>
  `).join('');
}

function render(id) {
  const j = D[id];
  document.querySelectorAll('.tab').forEach(t => t.classList.toggle('active', t.dataset.j===id));
  document.getElementById('summary').innerHTML = `
    <div class="sum-card sum-neutral">
      <div class="sum-id">${j.label}</div>
      <div class="sum-title">${j.desc}</div>
      <div class="sum-sub">${j.sub}</div>
    </div>
    <div class="sum-card sum-red">
      <div class="sum-label sum-label-red">Current problem</div>
      <div class="sum-val-red">${j.cur_tag}</div>
    </div>
    <div class="sum-card sum-green">
      <div class="sum-label sum-label-green">MVP outcome</div>
      <div class="sum-val-green">${j.mvp_tag}</div>
    </div>
  `;
  document.getElementById('cols').innerHTML = `
    <div>
      <div class="col-header col-header-red">
        <span class="col-title-red">Current state</span>
        <span class="col-sub">${j.cur_tag}</span>
      </div>
      ${renderCol(j.steps,'cur')}
    </div>
    <div>
      <div class="col-header col-header-green">
        <span class="col-title-green">MVP approach</span>
        <span class="col-sub">${j.mvp_tag}</span>
      </div>
      ${renderCol(j.steps,'mvp')}
    </div>
  `;
}

const tabsEl = document.getElementById('tabs');
Object.keys(D).forEach(id => {
  const btn = document.createElement('button');
  btn.className = 'tab' + (id===cur?' active':'');
  btn.dataset.j = id;
  btn.innerHTML = `<span class="tab-id">${D[id].label}</span><span class="tab-desc">${D[id].desc}</span>`;
  btn.onclick = () => { cur=id; render(id); };
  tabsEl.appendChild(btn);
});
render(cur);
</script>
</body>
</html>
